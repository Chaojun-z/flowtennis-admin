page {
  height: 100%;
  background: #F7F6F3;
}

.app-shell {
  height: 100vh;
  overflow: hidden;
  background: #F7F6F3;
  color: #2D2621;
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.page-scroll {
  height: calc(100vh - 112rpx - env(safe-area-inset-bottom));
}

.hero {
  padding: 108rpx 40rpx 120rpx;
  border-bottom-left-radius: 40px;
  border-bottom-right-radius: 40px;
  background: linear-gradient(135deg, #B3632A 0%, #C77840 100%);
}

.coach-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.coach-avatar {
  width: 88rpx;
  height: 88rpx;
  border: 1px solid rgba(255,255,255,.2);
  border-radius: 999px;
  background: rgba(255,255,255,.1);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-title {
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 6rpx;
  color: #FFF2EB;
  font-size: 24rpx;
}

.stats-card {
  margin: -90rpx 32rpx 40rpx;
  padding: 40rpx 0;
  border-radius: 24px;
  background: #fff;
  box-shadow: 0 16rpx 60rpx rgba(179,99,42,.08);
  display: flex;
  flex-wrap: wrap;
}

.stat-item {
  width: 33.33%;
  text-align: center;
  margin-bottom: 36rpx;
  box-sizing: border-box;
  border-right: 1px solid #F0EFEB;
}

.stat-item:nth-child(3n) {
  border-right: 0;
}

.stat-item.small {
  margin-bottom: 0;
}

.stat-label {
  display: block;
  color: #827870;
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.stat-number {
  color: #2D2621;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
}

.small-number {
  font-size: 36rpx;
}

.danger,
.danger-text {
  color: #D05238;
}

.content-section,
.list-section {
  padding: 0 32rpx 40rpx;
}

.notice-card {
  padding: 26rpx 32rpx;
  border: 1px solid #EBE8E3;
  border-radius: 16px;
  background: #FCFBF9;
  color: #5C544D;
  font-size: 26rpx;
  margin-bottom: 28rpx;
}

.section-title {
  margin: 0 0 24rpx 4rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.section-title text {
  color: #B5AAA2;
  font-size: 26rpx;
  font-weight: 400;
}

.lesson-card,
.student-card,
.shift-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border: 1px solid #F0EFEB;
  border-radius: 20px;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(45,38,33,.02);
}

.lesson-head,
.shift-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.lesson-time {
  font-size: 30rpx;
  color: #2D2621;
  font-weight: 700;
}

.status-tag {
  padding: 4rpx 14rpx;
  border-radius: 4px;
  font-size: 22rpx;
  font-weight: 700;
}

.tag-danger {
  background: #FFF0EE;
  color: #D05238;
}

.tag-green {
  background: #F2F6ED;
  color: #698A4E;
}

.lesson-info {
  padding: 24rpx;
  border-radius: 12px;
  background: #FCFBF9;
}

.lesson-student {
  margin-bottom: 12rpx;
  font-size: 30rpx;
  color: #2D2621;
  font-weight: 700;
}

.lesson-meta {
  color: #827870;
  font-size: 24rpx;
}

.type-pill {
  display: inline-block;
  margin-right: 16rpx;
  padding: 4rpx 12rpx;
  border: 1px solid #EBE8E3;
  border-radius: 4px;
  background: #fff;
  color: #B3632A;
  font-size: 20rpx;
  font-weight: 700;
}

.lesson-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 28rpx;
}

button {
  margin: 0;
  border-radius: 8px;
}

button::after {
  border: 0;
}

.ghost-btn,
.solid-btn,
.outline-btn,
.primary-btn {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.ghost-btn {
  flex: 1;
  background: #FCFBF9;
  color: #5C544D;
  border: 1px solid #EBE8E3;
}

.solid-btn,
.primary-btn {
  flex: 1;
  background: #B3632A;
  color: #fff;
}

.outline-btn {
  flex: 1;
  background: #fff;
  color: #B3632A;
  border: 1px solid #B3632A;
}

.timetable-page {
  height: calc(100vh - 112rpx - env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  background: #fff;
}

.timetable-header,
.simple-header {
  padding: 108rpx 32rpx 40rpx;
  border-bottom-left-radius: 24px;
  border-bottom-right-radius: 24px;
  background: #B3632A;
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(45,38,33,.05);
}

.nav-title,
.simple-header text {
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
}

.week-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 32rpx;
}

.week-switch {
  height: 72rpx;
  padding: 4rpx;
  border-radius: 999px;
  background: rgba(255,255,255,.2);
  display: flex;
  align-items: center;
}

.circle-btn {
  width: 64rpx;
  height: 64rpx;
  line-height: 56rpx;
  border-radius: 999px;
  background: transparent;
  color: #fff;
  font-size: 42rpx;
}

.week-range {
  min-width: 180rpx;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.today-btn {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 32rpx;
  border-radius: 999px;
  background: #fff;
  color: #B3632A;
  font-size: 24rpx;
  font-weight: 700;
}

.timetable-scroll {
  flex: 1;
  white-space: nowrap;
}

.grid-header,
.grid-body,
.day-columns {
  display: flex;
}

.grid-header {
  position: sticky;
  top: 0;
  z-index: 20;
  background: #fff;
  border-bottom: 1px solid #F0EFEB;
}

.time-corner,
.time-axis {
  width: 104rpx;
  flex-shrink: 0;
  background: rgba(255,255,255,.9);
  border-right: 1px solid #F0EFEB;
}

.day-column-head,
.day-column {
  width: 288rpx;
  flex-shrink: 0;
  border-right: 1px solid #F0EFEB;
  box-sizing: border-box;
}

.day-column-head {
  height: 92rpx;
  padding-top: 16rpx;
  text-align: center;
}

.today-head,
.today-column {
  background: rgba(255,242,234,.6);
}

.day-name {
  display: block;
  color: #5C544D;
  font-size: 26rpx;
  font-weight: 700;
}

.day-date {
  display: block;
  color: #B5AAA2;
  font-size: 22rpx;
  margin-top: 4rpx;
}

.hour-cell,
.grid-hour {
  height: 90rpx;
  border-bottom: 1px solid rgba(240,239,235,.6);
  box-sizing: border-box;
}

.hour-cell {
  display: flex;
  justify-content: center;
}

.hour-cell text {
  margin-top: -12rpx;
  padding: 0 6rpx;
  background: #fff;
  color: #B5AAA2;
  font-size: 22rpx;
}

.day-column {
  position: relative;
}

.grid-empty {
  position: absolute;
  top: 60rpx;
  left: 24rpx;
  right: 24rpx;
  padding: 28rpx 8rpx;
  border: 1px dashed #E0CDBE;
  border-radius: 14px;
  background: rgba(252,251,249,.5);
  color: #B5967E;
  text-align: center;
  font-size: 24rpx;
}

.grid-course {
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  padding: 18rpx;
  border: 1px solid #DCE4EC;
  border-radius: 10px;
  background: #EEF2FC;
  box-shadow: 0 2rpx 8rpx rgba(45,38,33,.04);
  overflow: hidden;
  box-sizing: border-box;
}

.grid-course-top {
  display: flex;
  justify-content: space-between;
  color: #2C4A8D;
  font-size: 22rpx;
  font-weight: 700;
}

.grid-course-name {
  margin-top: 6rpx;
  color: #2D2621;
  font-size: 26rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
}

.grid-course-meta,
.grid-course-foot {
  margin-top: 4rpx;
  color: #827870;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 40;
  height: calc(112rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1px solid #EDEBE6;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.tab-item {
  width: 25%;
  color: #B5AAA2;
  font-size: 20rpx;
  font-weight: 500;
  text-align: center;
}

.tab-item.active {
  color: #B3632A;
  font-weight: 700;
}

.tab-icon {
  display: block;
  margin-bottom: 2rpx;
  font-size: 40rpx;
}

.student-summary,
.shift-summary {
  margin: -20rpx 32rpx 32rpx;
  padding: 28rpx;
  border-radius: 16px;
  background: rgba(255,255,255,.12);
  color: #fff;
  display: flex;
  justify-content: space-around;
  text-align: center;
}

.summary-num {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
}

.student-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.student-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 999px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
}

.avatar-warm { background: #F3EBE3; color: #B08968; }
.avatar-teal { background: #E6EEED; color: #6B9690; }
.avatar-green { background: #E8EDE3; color: #7A996D; }
.avatar-purple { background: #EBE7EE; color: #867B9A; }

.student-main {
  flex: 1;
}

.student-name,
.shift-name {
  color: #2D2621;
  font-size: 32rpx;
  font-weight: 700;
}

.student-tag {
  margin-left: 16rpx;
  padding: 4rpx 12rpx;
  border-radius: 4px;
  background: #FFF2EA;
  color: #B3632A;
  font-size: 20rpx;
  font-weight: 700;
}

.student-meta,
.shift-meta {
  margin-top: 12rpx;
  color: #827870;
  font-size: 24rpx;
}

.chevron {
  color: #DCD6D0;
  font-size: 44rpx;
}

.mask {
  position: fixed;
  inset: 0;
  z-index: 50;
  background: rgba(45,38,33,.5);
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 51;
  max-height: 85vh;
  border-top-left-radius: 32px;
  border-top-right-radius: 32px;
  background: #F7F6F3;
  transform: translateY(100%);
  transition: transform .3s ease;
  overflow: hidden;
}

.sheet-show {
  transform: translateY(0);
}

.sheet-handle {
  width: 80rpx;
  height: 12rpx;
  margin: 24rpx auto 8rpx;
  border-radius: 999px;
  background: #DCD6D0;
}

.sheet-title,
.poster-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 48rpx;
  color: #2D2621;
  font-size: 34rpx;
  font-weight: 700;
}

.sheet-title button,
.poster-head button {
  width: 64rpx;
  height: 64rpx;
  line-height: 56rpx;
  border-radius: 999px;
  background: #EBE8E3;
  color: #827870;
  font-size: 32rpx;
}

.sheet-body {
  max-height: 60vh;
  padding: 20rpx 40rpx 180rpx;
  box-sizing: border-box;
}

.block-title {
  margin-bottom: 24rpx;
  color: #B3632A;
  font-size: 26rpx;
  font-weight: 700;
}

.info-card {
  padding: 0 32rpx;
  border: 1px solid #F0EFEB;
  border-radius: 16px;
  background: #fff;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1px solid #F0EFEB;
  color: #827870;
  font-size: 26rpx;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-row text:last-child {
  max-width: 430rpx;
  color: #2D2621;
  text-align: right;
  font-weight: 500;
}

.sheet-actions {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1px solid #F0EFEB;
  background: rgba(255,255,255,.9);
  display: flex;
  gap: 24rpx;
}

.sheet-actions.three {
  gap: 16rpx;
}

.feedback-context {
  margin-bottom: 40rpx;
  padding: 24rpx 32rpx;
  border-radius: 12px;
  background: #EBE8E3;
  color: #5C544D;
  font-size: 24rpx;
}

.field-label {
  margin-bottom: 16rpx;
  color: #2D2621;
  font-size: 28rpx;
  font-weight: 700;
}

.field-label text {
  color: #D05238;
}

.feedback-input {
  width: 100%;
  height: 200rpx;
  padding: 28rpx;
  border: 1px solid #F0EFEB;
  border-radius: 16px;
  background: #fff;
  box-sizing: border-box;
  font-size: 28rpx;
}

.poster-layer {
  position: fixed;
  inset: 0;
  z-index: 60;
  background: #F7F6F3;
  padding-top: env(safe-area-inset-top);
}

.poster-tabs {
  white-space: nowrap;
  padding: 0 32rpx 28rpx;
}

.poster-tab {
  display: inline-block;
  margin-right: 20rpx;
  padding: 16rpx 28rpx;
  border: 1px solid #EBE8E3;
  border-radius: 8px;
  background: #fff;
  color: #5C544D;
  font-size: 26rpx;
  font-weight: 700;
}

.poster-tab.active {
  background: #B3632A;
  color: #fff;
}

.poster-card {
  height: 860rpx;
  margin: 0 48rpx;
  padding: 48rpx;
  border-radius: 16px;
  background: linear-gradient(135deg, #2E4C6D 0%, #39638B 55%, #4073A0 100%);
  color: #fff;
  box-shadow: 0 24rpx 60rpx rgba(45,38,33,.18);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-sizing: border-box;
}

.poster-title {
  font-size: 56rpx;
  font-weight: 700;
}

.poster-title text,
.poster-date,
.poster-brand text {
  display: block;
  font-size: 22rpx;
  font-weight: 400;
  opacity: .8;
}

.poster-note {
  padding: 28rpx;
  border: 1px solid rgba(255,255,255,.2);
  border-radius: 12px;
  background: rgba(255,255,255,.1);
}

.poster-note text {
  display: block;
  margin-bottom: 10rpx;
}

.poster-brand {
  font-size: 36rpx;
  font-weight: 700;
}

.poster-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1px solid #F0EFEB;
  background: #fff;
  display: flex;
  gap: 24rpx;
}

.poster-actions button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-weight: 700;
}

.poster-actions button:last-child {
  background: #B3632A;
  color: #fff;
}

.state-text {
  padding: 120rpx 0;
  color: #B3632A;
  text-align: center;
  font-size: 30rpx;
}

.empty-box {
  margin: 160rpx 40rpx;
  padding: 48rpx 40rpx;
  border-radius: 16px;
  background: #fff;
}

.empty-title {
  display: block;
  color: #6f6258;
  font-size: 28rpx;
  line-height: 1.6;
  text-align: center;
}

.primary-btn {
  margin-top: 32rpx;
}
