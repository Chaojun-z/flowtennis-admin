page {
  height: 100%;
  background: #F7F6F3;
}

.app-shell {
  height: 100vh;
  overflow: hidden;
  background: #F7F6F3;
  color: #2D2621;
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.page-scroll {
  height: calc(100vh - 112rpx - env(safe-area-inset-bottom));
  background: #F7F6F3;
}

.dashboard-scroll {
  background: #F7F6F3;
}

.hero {
  background: #B3743E;
  color: #fff;
}

.dashboard-hero {
  padding: 92rpx 36rpx 132rpx;
}

.coach-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.coach-avatar {
  width: 78rpx;
  height: 78rpx;
  border: 1px solid rgba(255,255,255,.28);
  border-radius: 999px;
  background: rgba(255,255,255,.08);
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.hero-subtitle {
  margin-top: 8rpx;
  color: rgba(255,255,255,.92);
  font-size: 24rpx;
}

.stats-card {
  margin: -88rpx 28rpx 36rpx;
  padding: 36rpx 0 34rpx;
  border-radius: 28px;
  background: #fff;
  box-shadow: 0 16rpx 36rpx rgba(45,38,33,.05);
  display: flex;
  flex-wrap: wrap;
}

.stat-item {
  position: relative;
  width: 33.33%;
  margin-bottom: 34rpx;
  text-align: center;
  box-sizing: border-box;
}

.stat-item::after {
  content: "";
  position: absolute;
  top: 12rpx;
  right: 0;
  width: 1px;
  height: 64rpx;
  background: #ECE7E1;
}

.stat-item:nth-child(3n)::after {
  display: none;
}

.stat-item.small {
  margin-bottom: 0;
}

.stat-label {
  display: block;
  color: #7E7771;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.stat-number {
  display: block;
  color: #2D2621;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1;
}

.small-number {
  font-size: 34rpx;
}

.danger,
.danger-text {
  color: #C45B45;
}

.content-section,
.list-section {
  padding: 0 28rpx 40rpx;
}

.notice-card {
  padding: 26rpx 30rpx;
  border: 1px solid #EAE6DF;
  border-radius: 18px;
  background: #fff;
  color: #625A53;
  font-size: 27rpx;
  line-height: 1.55;
  box-shadow: 0 8rpx 24rpx rgba(45,38,33,.03);
  margin-bottom: 34rpx;
}

.summary-notice {
  text-align: center;
  font-weight: 700;
}

.notice-icon {
  margin-right: 14rpx;
  color: #A9A099;
}

.section-title {
  margin: 0 0 24rpx 8rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.section-title text {
  margin-left: 12rpx;
  color: #A9A099;
  font-size: 24rpx;
  font-weight: 700;
}

.lesson-card,
.student-card,
.shift-card {
  margin-bottom: 28rpx;
  padding: 28rpx;
  border: 1px solid #EEEAE4;
  border-radius: 24px;
  background: #fff;
  box-shadow: 0 8rpx 22rpx rgba(45,38,33,.04);
}

.lesson-head,
.shift-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.lesson-time {
  color: #2D2621;
  font-size: 31rpx;
  font-weight: 900;
}

.clock-icon {
  margin-right: 12rpx;
  color: #A9A099;
  font-size: 28rpx;
}

.status-tag {
  padding: 8rpx 18rpx;
  border-radius: 7px;
  font-size: 23rpx;
  font-weight: 800;
}

.tag-danger {
  background: #FDF0EE;
  color: #C45B45;
}

.tag-green {
  background: #EEF6EA;
  color: #64874C;
}

.lesson-info {
  padding: 26rpx 24rpx;
  border: 1px solid #F1EEE9;
  border-radius: 18px;
  background: #FCFBF9;
}

.lesson-student {
  margin-bottom: 14rpx;
  color: #2D2621;
  font-size: 32rpx;
  font-weight: 900;
}

.lesson-meta {
  color: #7E7771;
  font-size: 25rpx;
}

.type-pill {
  display: inline-block;
  margin-right: 16rpx;
  padding: 6rpx 12rpx;
  border: 1px solid #E8E2DB;
  border-radius: 5px;
  background: #fff;
  color: #B3743E;
  font-size: 22rpx;
  font-weight: 800;
}

.lesson-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

button {
  margin: 0;
  border-radius: 8px;
}

button::after {
  border: 0;
}

.ghost-btn,
.solid-btn,
.outline-btn,
.primary-btn {
  height: 72rpx;
  line-height: 72rpx;
  font-size: 27rpx;
  font-weight: 800;
}

.ghost-btn {
  flex: 1;
  background: #fff;
  color: #5C544D;
  border: 1px solid #E8E2DB;
}

.solid-btn,
.primary-btn {
  flex: 1;
  background: #B3743E;
  color: #fff;
}

.outline-btn {
  flex: 1;
  background: #fff;
  color: #B3743E;
  border: 1px solid #B3743E;
}

.timetable-page {
  height: calc(100vh - 112rpx - env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  background: #fff;
}

.timetable-header,
.simple-header {
  padding: 96rpx 28rpx 38rpx;
  border-bottom-left-radius: 28px;
  border-bottom-right-radius: 28px;
  background: #B3743E;
  color: #fff;
}

.nav-title,
.simple-header > text {
  display: block;
  text-align: center;
  font-size: 34rpx;
  font-weight: 900;
}

.week-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 42rpx;
}

.week-switch {
  width: 306rpx;
  height: 68rpx;
  padding: 0 14rpx;
  border-radius: 999px;
  background: rgba(255,255,255,.18);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.circle-btn {
  width: 54rpx;
  height: 54rpx;
  line-height: 48rpx;
  border-radius: 999px;
  background: transparent;
  color: #fff;
  font-size: 44rpx;
  font-weight: 800;
}

.week-range {
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
}

.today-btn {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 28rpx;
  border-radius: 999px;
  background: #fff;
  color: #A86231;
  font-size: 24rpx;
  font-weight: 800;
}

.timetable-scroll {
  flex: 1;
  white-space: nowrap;
  background: #fff;
}

.grid-header,
.grid-body,
.day-columns {
  display: flex;
}

.grid-header {
  position: sticky;
  top: 0;
  z-index: 20;
  background: #fff;
  border-bottom: 1px solid #EDEBE6;
}

.time-corner,
.time-axis {
  width: 86rpx;
  flex-shrink: 0;
  background: #fff;
  border-right: 1px solid #EDEBE6;
}

.day-column-head,
.day-column {
  width: 240rpx;
  flex-shrink: 0;
  border-right: 1px solid #EDEBE6;
  box-sizing: border-box;
}

.day-column-head {
  height: 92rpx;
  padding-top: 18rpx;
  text-align: center;
}

.today-head,
.today-column {
  background: #FCF8F4;
}

.day-name {
  display: block;
  color: #5C544D;
  font-size: 26rpx;
  font-weight: 900;
}

.day-date {
  display: block;
  color: #A9A099;
  font-size: 22rpx;
  margin-top: 4rpx;
}

.today-head .day-name,
.today-head .day-date {
  color: #B3743E;
}

.hour-cell,
.grid-hour {
  height: 150rpx;
  border-bottom: 1px solid rgba(237,235,230,.75);
  box-sizing: border-box;
}

.hour-cell {
  display: flex;
  justify-content: center;
}

.hour-cell text {
  margin-top: -13rpx;
  padding: 0 4rpx;
  background: #fff;
  color: #9F9992;
  font-size: 22rpx;
}

.day-columns,
.day-column {
  position: relative;
}

.grid-empty {
  position: absolute;
  top: 52rpx;
  left: 22rpx;
  right: 22rpx;
  height: 84rpx;
  line-height: 84rpx;
  border: 1px dashed #E1CDBB;
  border-radius: 15px;
  background: rgba(252,251,249,.75);
  color: #A8917F;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
}

.grid-course {
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  padding: 18rpx;
  border: 1px solid #D8E0EA;
  border-radius: 12px;
  background: #EEF2FA;
  box-shadow: 0 4rpx 12rpx rgba(45,38,33,.04);
  overflow: hidden;
  box-sizing: border-box;
}

.grid-course-top {
  display: flex;
  justify-content: space-between;
  color: #2C4A8D;
  font-size: 22rpx;
  font-weight: 900;
}

.grid-course-name {
  margin-top: 8rpx;
  color: #2D2621;
  font-size: 28rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
}

.grid-course-meta,
.grid-course-foot {
  margin-top: 6rpx;
  color: #6F6862;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.grid-course-foot {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 16rpx;
}

.now-line {
  position: absolute;
  left: 0;
  right: 0;
  top: 975rpx;
  z-index: 25;
  height: 1px;
  background: #C95742;
}

.now-line text {
  position: absolute;
  left: -80rpx;
  top: -18rpx;
  width: 74rpx;
  height: 36rpx;
  line-height: 36rpx;
  border-radius: 999px;
  background: #C95742;
  color: #fff;
  text-align: center;
  font-size: 22rpx;
  font-weight: 900;
}

.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 40;
  height: calc(112rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1px solid #EDEBE6;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.tab-item {
  width: 25%;
  color: #B2AAA3;
  font-size: 21rpx;
  font-weight: 700;
  text-align: center;
}

.tab-item.active {
  color: #B3743E;
}

.tab-icon {
  display: block;
  margin-bottom: 2rpx;
  font-size: 38rpx;
  line-height: 1;
}

.student-summary {
  margin-top: 48rpx;
  padding: 28rpx 0;
  border: 1px solid rgba(255,255,255,.18);
  border-radius: 18px;
  background: rgba(255,255,255,.1);
  color: #fff;
  display: flex;
  justify-content: space-around;
  text-align: center;
}

.summary-divider {
  width: 1px;
  background: rgba(255,255,255,.35);
}

.shift-summary {
  margin: -36rpx 28rpx 34rpx;
  display: flex;
  gap: 20rpx;
}

.shift-summary > view {
  flex: 1;
  padding: 28rpx;
  border-radius: 18px;
  background: #fff;
  color: #827870;
  box-shadow: 0 6rpx 18rpx rgba(45,38,33,.04);
}

.summary-label {
  display: block;
  font-size: 23rpx;
  margin-bottom: 12rpx;
}

.summary-num {
  display: block;
  font-size: 52rpx;
  font-weight: 900;
}

.summary-num.dark {
  color: #2D2621;
  font-size: 42rpx;
}

.summary-num.dark text {
  margin-left: 4rpx;
  color: #827870;
  font-size: 22rpx;
  font-weight: 500;
}

.student-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx;
}

.student-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 999px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 900;
}

.avatar-warm { background: #F3EBE3; color: #B08968; }
.avatar-teal { background: #E6EEED; color: #6B9690; }
.avatar-green { background: #E8EDE3; color: #7A996D; }
.avatar-purple { background: #EBE7EE; color: #867B9A; }

.student-main {
  flex: 1;
}

.student-name,
.shift-name {
  color: #2D2621;
  font-size: 32rpx;
  font-weight: 900;
}

.student-tag {
  margin-left: 14rpx;
  padding: 5rpx 12rpx;
  border-radius: 5px;
  background: #FFF2EA;
  color: #B3743E;
  font-size: 20rpx;
  font-weight: 800;
}

.student-meta,
.shift-meta {
  margin-top: 14rpx;
  color: #827870;
  font-size: 25rpx;
  line-height: 1.5;
}

.chevron {
  color: #D1CBC5;
  font-size: 48rpx;
}

.shift-card {
  padding: 34rpx;
}

.mask {
  position: fixed;
  inset: 0;
  z-index: 50;
  background: rgba(45,38,33,.5);
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 51;
  max-height: 85vh;
  border-top-left-radius: 32px;
  border-top-right-radius: 32px;
  background: #F7F6F3;
  transform: translateY(100%);
  transition: transform .3s ease;
  overflow: hidden;
}

.sheet-show {
  transform: translateY(0);
}

.sheet-handle {
  width: 80rpx;
  height: 12rpx;
  margin: 24rpx auto 8rpx;
  border-radius: 999px;
  background: #DCD6D0;
}

.sheet-title,
.poster-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 48rpx;
  color: #2D2621;
  font-size: 34rpx;
  font-weight: 900;
}

.sheet-title button,
.poster-head button {
  width: 64rpx;
  height: 64rpx;
  line-height: 56rpx;
  border-radius: 999px;
  background: #EBE8E3;
  color: #827870;
  font-size: 32rpx;
}

.sheet-body {
  max-height: 60vh;
  padding: 20rpx 40rpx 180rpx;
  box-sizing: border-box;
}

.block-title {
  margin-bottom: 24rpx;
  color: #B3743E;
  font-size: 26rpx;
  font-weight: 800;
}

.info-card {
  padding: 0 32rpx;
  border: 1px solid #F0EFEB;
  border-radius: 16px;
  background: #fff;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1px solid #F0EFEB;
  color: #827870;
  font-size: 26rpx;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-row text:last-child {
  max-width: 430rpx;
  color: #2D2621;
  text-align: right;
  font-weight: 700;
}

.sheet-actions {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1px solid #F0EFEB;
  background: rgba(255,255,255,.9);
  display: flex;
  gap: 20rpx;
}

.sheet-actions.three {
  gap: 14rpx;
}

.feedback-context {
  margin-bottom: 40rpx;
  padding: 24rpx 32rpx;
  border-radius: 12px;
  background: #EBE8E3;
  color: #5C544D;
  font-size: 24rpx;
}

.field-label {
  margin-bottom: 16rpx;
  color: #2D2621;
  font-size: 28rpx;
  font-weight: 800;
}

.field-label text {
  color: #D05238;
}

.feedback-input {
  width: 100%;
  height: 200rpx;
  padding: 28rpx;
  border: 1px solid #F0EFEB;
  border-radius: 16px;
  background: #fff;
  box-sizing: border-box;
  font-size: 28rpx;
}

.poster-layer {
  position: fixed;
  inset: 0;
  z-index: 60;
  background: #F7F6F3;
  padding-top: env(safe-area-inset-top);
}

.poster-tabs {
  white-space: nowrap;
  padding: 0 32rpx 28rpx;
}

.poster-tab {
  display: inline-block;
  margin-right: 20rpx;
  padding: 16rpx 28rpx;
  border: 1px solid #EBE8E3;
  border-radius: 8px;
  background: #fff;
  color: #5C544D;
  font-size: 26rpx;
  font-weight: 800;
}

.poster-tab.active {
  background: #B3743E;
  color: #fff;
}

.poster-card {
  height: 860rpx;
  margin: 0 48rpx;
  padding: 48rpx;
  border-radius: 16px;
  background: linear-gradient(135deg, #2E4C6D 0%, #39638B 55%, #4073A0 100%);
  color: #fff;
  box-shadow: 0 24rpx 60rpx rgba(45,38,33,.18);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-sizing: border-box;
}

.poster-title {
  font-size: 56rpx;
  font-weight: 900;
}

.poster-title text,
.poster-date,
.poster-brand text {
  display: block;
  font-size: 22rpx;
  font-weight: 400;
  opacity: .8;
}

.poster-note {
  padding: 28rpx;
  border: 1px solid rgba(255,255,255,.2);
  border-radius: 12px;
  background: rgba(255,255,255,.1);
}

.poster-note text {
  display: block;
  margin-bottom: 10rpx;
}

.poster-brand {
  font-size: 36rpx;
  font-weight: 900;
}

.poster-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1px solid #F0EFEB;
  background: #fff;
  display: flex;
  gap: 24rpx;
}

.poster-actions button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-weight: 800;
}

.poster-actions button:last-child {
  background: #B3743E;
  color: #fff;
}

.state-text {
  padding: 120rpx 0;
  color: #B3743E;
  text-align: center;
  font-size: 30rpx;
}

.empty-box {
  margin: 160rpx 40rpx;
  padding: 48rpx 40rpx;
  border-radius: 16px;
  background: #fff;
}

.empty-title {
  display: block;
  color: #6f6258;
  font-size: 28rpx;
  line-height: 1.6;
  text-align: center;
}

.primary-btn {
  margin-top: 32rpx;
}
