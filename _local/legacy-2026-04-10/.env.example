# FlowTennis environment variables
# Copy this file to `.env` for local development.

# Required: JWT signing secret
JWT_SECRET=replace-with-your-jwt-secret

# Required: Alibaba Cloud TableStore endpoint
TS_ENDPOINT=https://your-instance.region.ots.aliyuncs.com

# Optional: TableStore instance name
TS_INSTANCE=flowtennis

# Required: Alibaba Cloud access key ID
ALIBABA_CLOUD_ACCESS_KEY_ID=replace-with-your-access-key-id

# Required: Alibaba Cloud access key secret
ALIBABA_CLOUD_ACCESS_KEY_SECRET=replace-with-your-access-key-secret

# Optional: enable default user bootstrap only for controlled initialization
ENABLE_DEFAULT_USER_BOOTSTRAP=false
